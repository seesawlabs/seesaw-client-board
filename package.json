{
  "name": "seesaw-client-board",
  "version": "1.0.0",
  "description": "A shared, editable team standup board for SeeSaw Labs — active client engagements, a portfolio-level calendar view, and a pipeline of potential new opportunities. Built as a single-file React component that runs as a **Claude.ai artifact**.",
